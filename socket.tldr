										{
											"type": "bold"
										}
									],
									"text": "1. Socket connection:"
								},
								{
									"type": "text",
									"text": " Exactly the same as that of server’s socket creation"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "ltr"
