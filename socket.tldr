								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "It extracts the first connection request on the queue of pending connections for the listening socket, "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "sockfd, creates a new connected socket, and returns a new file descriptor referring to that socket."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": " At this point, the connection is established between client and server, and they are ready to transfer data."
								}
							]
						}
					]
				}
			},
			"parentId": "page:page",
			"index": "ab3sh",
			"typeName": "shape"
